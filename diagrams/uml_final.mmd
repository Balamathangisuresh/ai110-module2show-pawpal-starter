classDiagram
    class Task {
        +String title
        +int duration_minutes
        +String priority
        +String frequency
        +String start_time
        +bool completed
        +date due_date
        +mark_complete() None
        +mark_incomplete() None
        +next_occurrence() Task
        +priority_score() int
        +__repr__() String
    }

    class Pet {
        +String name
        +String species
        +String breed
        +int age
        +List tasks
        +summary() String
        +add_task(task) None
        +remove_task(title) None
    }

    class Owner {
        +String name
        +int available_minutes
        +List pets
        +add_pet(pet) None
        +has_time_for(task) bool
    }

    class Scheduler {
        +Owner owner
        +List planned_tasks
        +List skipped_tasks
        +mark_task_complete(task) Task
        +build_schedule() None
        +check_conflicts() List
        +conflict_warnings() List
        +filter_tasks(status, pet_name) List
        +total_duration() int
        +display() String
        -_sort_by_priority() List
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : uses
    Owner ..> Task : checks time for
    Scheduler ..> Pet : reads/updates tasks on
    Scheduler ..> Task : marks complete
    Task ..> Task : spawns next occurrence
